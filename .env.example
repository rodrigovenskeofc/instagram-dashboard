# ────────────────────────────────────────────────────────
# Variáveis de ambiente — copie para .env e preencha
# NÃO commite o arquivo .env no GitHub
# ────────────────────────────────────────────────────────

# Token de longa duração gerado pelo Instagram Login for Business
# Válido por 60 dias — renovar via trocar.py antes do vencimento
INSTAGRAM_ACCESS_TOKEN=SEU_TOKEN_AQUI

# ID numérico da conta Instagram Business
INSTAGRAM_BUSINESS_ID=26890120633982173

# Versão da API Meta (não alterar sem necessidade)
META_API_VERSION=v19.0

# App ID e Secret do app Meta (Instagram API)
META_APP_ID=1323414296559053
META_APP_SECRET=SEU_APP_SECRET_AQUI

# Senha opcional para proteger o endpoint /api/refresh
# Coloque qualquer string aleatória, ex: "dashboard2026abc"
REFRESH_SECRET=ESCOLHA_UMA_SENHA_AQUI
